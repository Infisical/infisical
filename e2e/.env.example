# SCIM token for the gamma e2e org. Created by backend/scripts/seed-gamma-fixtures.ts
# and stored in the infrastructure repo's GH Actions secrets.
E2E_SCIM_TOKEN=

# Shared secret the test sends as `Authorization: Bearer` to POST /saml-idp/identity.
# Same value as the SAML_IDP_ADMIN_TOKEN secret set on preview-environments.
E2E_IDP_ADMIN_TOKEN=

# Other config (gamma URL, org slug, IdP URL, SAML config id) is hardcoded
# in e2e/helpers/constants.ts — none of those are secrets and keeping them in
# code means CI only needs the two tokens above.
