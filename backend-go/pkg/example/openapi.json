{
  "components": {
    "securitySchemes": {
      "apiKey": {
        "in": "header",
        "name": "X-API-Key",
        "type": "apiKey"
      },
      "bearer": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Demonstrates unions, tri-state PATCH, validation, and OpenAPI generation",
    "title": "Example API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/auth/{orgSlug}/login": {
      "post": {
        "operationId": "login",
        "parameters": [
          {
            "in": "path",
            "name": "orgSlug",
            "required": true,
            "schema": {
              "pattern": "^[a-z0-9-]+$",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "authMethod": {
                    "discriminator": {
                      "propertyName": "method"
                    },
                    "oneOf": [
                      {
                        "properties": {
                          "method": {
                            "enum": [
                              "password"
                            ],
                            "type": "string"
                          },
                          "password": {
                            "minLength": 8,
                            "type": "string"
                          },
                          "username": {
                            "minLength": 1,
                            "type": "string"
                          }
                        },
                        "required": [
                          "username",
                          "password"
                        ],
                        "type": "object"
                      },
                      {
                        "properties": {
                          "method": {
                            "enum": [
                              "saml"
                            ],
                            "type": "string"
                          },
                          "samlResponse": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "samlResponse"
                        ],
                        "type": "object"
                      },
                      {
                        "properties": {
                          "code": {
                            "type": "string"
                          },
                          "method": {
                            "enum": [
                              "oidc"
                            ],
                            "type": "string"
                          },
                          "redirectUri": {
                            "format": "url",
                            "type": "string"
                          }
                        },
                        "required": [
                          "code",
                          "redirectUri"
                        ],
                        "type": "object"
                      }
                    ]
                  }
                },
                "required": [
                  "authMethod"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "summary": "Login (union: password|saml|oidc)",
        "tags": [
          "auth"
        ]
      }
    },
    "/orgs/{orgId}/users": {
      "get": {
        "operationId": "listUsers",
        "parameters": [
          {
            "in": "query",
            "name": "role",
            "required": false,
            "schema": {
              "enum": [
                "admin",
                "member",
                "viewer"
              ],
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "orgId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "format": "int64",
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "default": 20,
              "format": "int64",
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "security": [
          {
            "bearer": []
          },
          {
            "apiKey": []
          }
        ],
        "summary": "List users",
        "tags": [
          "users"
        ]
      },
      "post": {
        "operationId": "createUser",
        "parameters": [
          {
            "in": "path",
            "name": "orgId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "email": {
                    "format": "email-strict",
                    "type": "string"
                  },
                  "name": {
                    "maxLength": 100,
                    "minLength": 1,
                    "type": "string"
                  },
                  "role": {
                    "enum": [
                      "admin",
                      "member",
                      "viewer"
                    ],
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "name",
                  "role"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "security": [
          {
            "bearer": []
          },
          {
            "apiKey": []
          }
        ],
        "summary": "Create user",
        "tags": [
          "users"
        ]
      }
    },
    "/orgs/{orgId}/users/{userId}": {
      "patch": {
        "operationId": "updateUser",
        "parameters": [
          {
            "in": "path",
            "name": "orgId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "name": {
                    "maxLength": 100,
                    "minLength": 1,
                    "nullable": true,
                    "type": "string"
                  },
                  "role": {
                    "enum": [
                      "admin",
                      "member",
                      "viewer"
                    ],
                    "nullable": true,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "security": [
          {
            "bearer": []
          },
          {
            "apiKey": []
          }
        ],
        "summary": "Update user (PATCH with tri-state)",
        "tags": [
          "users"
        ]
      }
    },
    "/projects/{projectId}/webhooks": {
      "post": {
        "operationId": "createWebhook",
        "parameters": [
          {
            "in": "path",
            "name": "projectId",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "enabled": {
                    "default": true,
                    "type": "boolean"
                  },
                  "events": {
                    "items": {
                      "enum": [
                        "secret.created",
                        "secret.updated",
                        "secret.deleted"
                      ],
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "name": {
                    "maxLength": 100,
                    "minLength": 1,
                    "type": "string"
                  },
                  "target": {
                    "discriminator": {
                      "propertyName": "type"
                    },
                    "oneOf": [
                      {
                        "properties": {
                          "channel": {
                            "pattern": "^#[a-z0-9_-]+$",
                            "type": "string"
                          },
                          "type": {
                            "enum": [
                              "slack"
                            ],
                            "type": "string"
                          },
                          "webhookUrl": {
                            "format": "url",
                            "type": "string"
                          }
                        },
                        "required": [
                          "webhookUrl"
                        ],
                        "type": "object"
                      },
                      {
                        "properties": {
                          "type": {
                            "enum": [
                              "discord"
                            ],
                            "type": "string"
                          },
                          "webhookUrl": {
                            "format": "url",
                            "type": "string"
                          }
                        },
                        "required": [
                          "webhookUrl"
                        ],
                        "type": "object"
                      },
                      {
                        "properties": {
                          "headers": {
                            "additionalProperties": {
                              "type": "string"
                            },
                            "type": "object"
                          },
                          "method": {
                            "enum": [
                              "POST",
                              "PUT"
                            ],
                            "type": "string"
                          },
                          "type": {
                            "enum": [
                              "http"
                            ],
                            "type": "string"
                          },
                          "url": {
                            "format": "url",
                            "type": "string"
                          }
                        },
                        "required": [
                          "url",
                          "method"
                        ],
                        "type": "object"
                      }
                    ]
                  }
                },
                "required": [
                  "target",
                  "name",
                  "events"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create webhook (union: http|slack|discord)",
        "tags": [
          "webhooks"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "description": "Authentication (password, SAML, OIDC)",
      "name": "auth"
    },
    {
      "description": "User management",
      "name": "users"
    },
    {
      "description": "Webhooks (HTTP, Slack, Discord)",
      "name": "webhooks"
    }
  ]
}
